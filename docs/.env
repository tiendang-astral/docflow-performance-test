# =============================================================================
# DocFlow Platform — Production Environment Template
# =============================================================================
#
# HƯỚNG DẪN:
#   1. Sao chép file này: cp .env.example .env.production
#   2. Điền đầy đủ GIÁ TRỊ THẬT vào tất cả các biến bên dưới
#   3. TUYỆT ĐỐI KHÔNG commit .env.production lên git
#
# Các biến có dấu (!) là BẮT BUỘC — deploy sẽ thất bại nếu để trống.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
LOG_LEVEL=INFO

# ── Public URLs (!) ───────────────────────────────────────────────────────────
# URL mà browser của người dùng dùng để gọi API backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:29002/api
# URL frontend (dùng cho CORS)
NEXT_PUBLIC_FRONTEND_URL=http://localhost:29007
# Branding
NEXT_PUBLIC_APP_NAME=DocFlow Platform
NEXT_PUBLIC_APP_TITLE=DocFlow Platform
NEXT_PUBLIC_APP_DESCRIPTION=Hệ thống xử lý và quản lý luồng hồ sơ bằng AI

# ── Database (!) ──────────────────────────────────────────────────────────────
POSTGRES_DB=docaiplatform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=bd465f15c74a6fde01132f3bc6ef91b9c7ba9ab2
POSTGRES_PORT=29001

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=29006

# ── MinIO Object Storage (!) ──────────────────────────────────────────────────
MINIO_API_PORT=29005
MINIO_CONSOLE_PORT=29004
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:29005
MINIO_ACCESS_KEY=docflowadmin
MINIO_SECRET_KEY=dFyzjldFv0BNUtAyJo81i3j96AvXzN/V
MINIO_USE_SSL=false
MINIO_PUBLIC_USE_SSL=false
MINIO_BUCKET=netmind
MINIO_COLLECTION=docaiplatform
MINIO_BUCKET_RAW=raw
MINIO_BUCKET_PROCESSED=processed
DOCAI_MINIO_NETWORK=docai-minio

# ── Security (!) ──────────────────────────────────────────────────────────────
# JWT signing key — tạo bằng: openssl rand -hex 32
JWT_SECRET_KEY=bc615ad9a9d9a22416080b51eac09275c3e2c07d2c324b714a80185f420ad9ec

# ── AI Gateway (!) ────────────────────────────────────────────────────────────
AI_GATEWAY_ENDPOINT=https://api.openai.com/v1
AI_GATEWAY_KEY=REPLACE_WITH_PROVIDER_API_KEY
AI_GATEWAY_MODEL=gpt-4o-mini

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=29002
FRONTEND_PORT=29007
DOCPROCESS_HEALTH_PORT=8002
PLATFORM_WORKER_HEALTH_PORT=8001

# ── CORS & Browser Security ───────────────────────────────────────────────────
# Liệt kê đầy đủ các origin được phép (không có trailing slash)
CORS_ALLOW_ORIGINS=http://localhost:29007,http://127.0.0.1:29007
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
ENABLE_HSTS=false
ENABLE_API_DOCS=true
ENABLE_METRICS_ENDPOINT=true

# ── Observability / Grafana (!) ───────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=TSA7t76msP7fgJXaA6NrmBW+2VF9CQ1q
GRAFANA_PORT=29112
PROMETHEUS_PORT=29111

# ── Worker Tuning ─────────────────────────────────────────────────────────────
BACKEND_WEB_CONCURRENCY=4
PLATFORM_GRACEFUL_SHUTDOWN_SECONDS=30
PLATFORM_STREAM_STALE_CLAIM_MS=900000
PLATFORM_FULL_FLOW_WAIT_SECONDS=900
PLATFORM_FULL_FLOW_POLL_SECONDS=5
DOCPROCESS_WORKER_CONCURRENCY=1
DOCPROCESS_STREAM_STALE_CLAIM_MS=3600000

# ── Runtime Paths ─────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
OUTPUT_DIR=/app/data/output

# ── OpenTelemetry (optional) ─────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SAMPLE_RATE=1.0
OTEL_TRACE_CONSOLE=false

# ── Proxy (nếu server đứng sau proxy) ────────────────────────────────────────
NO_PROXY=localhost,127.0.0.1,::1
no_proxy=localhost,127.0.0.1,::1
